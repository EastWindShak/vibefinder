# Copy to `backend/.env` when running the API outside Docker (e.g. `uvicorn`).
# In Docker, compose usually injects DATABASE_URL / SECRET_KEY instead.

# Database — use the same user/password/db as your Postgres instance
DATABASE_URL=postgresql+asyncpg://vibefinder:change-me@localhost:5432/vibefinder
DATABASE_URL_SYNC=postgresql://vibefinder:change-me@localhost:5432/vibefinder

# ChromaDB (optional / legacy paths in settings)
CHROMADB_HOST=localhost
CHROMADB_PORT=8000
CHROMADB_PERSIST_DIRECTORY=./chroma_data

# Security
SECRET_KEY=change-me-generate-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Fernet key for OAuth token encryption (32 url-safe base64 bytes)
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
OAUTH_ENCRYPTION_KEY=change-me-fernet-key

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# YouTube Music MCP server script (path relative to backend working directory)
MCP_YTMUSIC_SERVER_PATH=./app/mcp/youtube_music_server.py

# CORS
FRONTEND_URL=http://localhost:5173

# Last.fm — https://www.last.fm/api/account/create
LASTFM_API_KEY=

# Audio analysis (CLAP)
ENABLE_AUDIO_ANALYSIS=true
AUDIO_ANALYSIS_MODEL=laion/larger_clap_music

# Langfuse (optional)
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_ENABLED=true
