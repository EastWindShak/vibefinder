# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/vibefinder
DATABASE_URL_SYNC=postgresql://user:password@localhost:5432/vibefinder

# ChromaDB
CHROMADB_HOST=localhost
CHROMADB_PORT=8000
CHROMADB_PERSIST_DIRECTORY=./chroma_data

# Security
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Encryption key for OAuth tokens (Fernet key)
OAUTH_ENCRYPTION_KEY=your-fernet-key-here

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# YouTube Music MCP Server
MCP_YTMUSIC_SERVER_PATH=./app/mcp/youtube_music_server.py

# CORS
FRONTEND_URL=http://localhost:5173
