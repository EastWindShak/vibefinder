# Copy this file to `.env` in the repository root.
# Docker Compose loads `.env` automatically. Do not commit `.env`.

# PostgreSQL (align with backend DATABASE_URL if the API runs on the host)
POSTGRES_USER=vibefinder
POSTGRES_PASSWORD=change-me
POSTGRES_DB=vibefinder

# JWT / app secret (use a long random string in production)
SECRET_KEY=change-me-generate-a-long-random-string

# Ollama (service name is correct inside the default compose network)
OLLAMA_BASE_URL=http://vibefinder-ollama:11434
OLLAMA_MODEL=llama3.1

# Frontend / CORS
FRONTEND_URL=http://localhost:5173
# Used by Vite dev proxy in Docker (see frontend/docker-compose.yml)
VITE_API_URL=http://localhost:8000

# Last.fm — https://www.last.fm/api/account/create
LASTFM_API_KEY=

# Audio analysis (CLAP)
ENABLE_AUDIO_ANALYSIS=true
AUDIO_ANALYSIS_MODEL=laion/larger_clap_music

# Langfuse — create project keys in the Langfuse UI after first start
LANGFUSE_HOST=http://langfuse:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_NEXTAUTH_SECRET=change-me-min-32-chars-langfuse
LANGFUSE_SALT=change-me-min-16-chars-langfuse
LANGFUSE_URL=http://localhost:3000
LANGFUSE_TELEMETRY=false
